# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# LLOneBot 反向 WebSocket 地址
ONEBOT_WS_URL=ws://127.0.0.1:8080/onebot/v11/ws

# 机器人 QQ 号
BOT_QQ=你的机器人QQ号

# 允许使用机器人的用户 QQ 号（逗号分隔，为空则允许所有人）
ALLOWED_USERS=

# Persona system prompt 文件路径
PERSONA_PROMPT_FILE=../persona/system_prompt.md

# 上下文记忆轮数（保持最近 N 轮对话）
MEMORY_ROUNDS=10

# 回复温度（0-2，越高越随机）
TEMPERATURE=0.8
